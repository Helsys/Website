---
import { getContent, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
---

<section id="services" class="section services" aria-labelledby="services-title">
  <div class="container">
    <p class="section-label reveal">{t.services.sectionLabel}</p>
    <h2 id="services-title" class="services-title reveal">{t.services.title}</h2>
    <p class="services-intro reveal" style="--reveal-delay: 0.05s">{t.services.intro}</p>

    <ol class="services-list" role="list">
      {t.services.items.map((item, i) => (
        <li class="service-card reveal" style={`--reveal-delay: ${i * 0.07}s`}>
          <span class="service-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="service-content">
            <h3 class="service-title">{item.title}</h3>
            <p class="service-body">{item.body}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="tech reveal">
      <p class="tech-label">{t.services.techLabel}</p>
      <ul class="tech-list" role="list">
        {t.services.tech.map((tech) => (
          <li class="tech-item">{tech}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .services-title {
    font-size: var(--step-3);
    margin-bottom: var(--space-m);
    max-width: 18ch;
  }

  .services-intro {
    font-size: var(--step-1);
    color: var(--color-ink-soft);
    max-width: var(--measure);
    margin-bottom: var(--space-xl);
  }

  .services-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .service-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-m);
    padding-block: var(--space-l);
    border-top: var(--border);
    transition: background-color 0.3s var(--ease-out);
  }

  .service-card:last-child {
    border-bottom: var(--border);
  }

  /* Dark: lift the cards onto the same gently raised surface as the cert badge,
     so they read as discrete, premium panels instead of melting into the
     charcoal ground (where the bare top/bottom rules left them flat). Each card
     gets the elevated background, the fine lifted keyline (--color-line-strong),
     a rounded edge and a soft shadow. The list gains spacing so the panels
     breathe; the per-row top/bottom rules are dropped (the card border replaces
     them). overflow:hidden keeps the warm hover keyline tucked into the rounded
     corner. Light is untouched (stays the borderless rows with the tint hover). */
  :global(html[data-theme='dark']) .services-list {
    gap: var(--space-s);
  }

  :global(html[data-theme='dark']) .service-card,
  :global(html[data-theme='dark']) .service-card:last-child {
    padding: var(--space-l);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius);
    background: var(--color-bg-elevated);
    overflow: hidden;
    box-shadow: 0 2px 6px -3px rgba(0, 0, 0, 0.55);
    transition: background-color 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  /* A whisper of lift on hover, echoing the cert badge's elevated feel, while
     the warm left keyline (the ::before) keeps wiping in on top. */
  :global(html[data-theme='dark']) .service-card:hover {
    border-color: color-mix(in srgb, var(--color-warm) 30%, var(--color-line-strong));
    box-shadow: 0 10px 30px -20px rgba(0, 0, 0, 0.7);
  }

  /* The numbered index carries the warm accent in both themes, so the list of
     services reads as a lively, branded sequence: this is the warm voice's most
     visible home. Teal stays the lead elsewhere (section label, links). */
  .service-index {
    font-size: var(--step--1);
    font-variant-numeric: tabular-nums;
    color: var(--color-warm);
    font-weight: 600;
    padding-top: 0.4rem;
    /* Nudge right so the 2px warm keyline on the card's left edge (the ::before
       hover line, anchored at left:0) never runs across the digit. */
    padding-left: 0.5rem;
  }

  /* A whisper of teal wash on hover (light) plus a warm keyline that wipes in
     on the left edge in both themes, so each row feels alive on interaction
     without a heavy hover state. */
  .service-card {
    position: relative;
  }

  .service-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-warm);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.3s var(--ease-out);
  }

  .service-card:hover::before {
    transform: scaleY(1);
  }

  :global(html[data-theme='light']) .service-card:hover {
    background-color: var(--color-surface-tint);
  }

  .service-title {
    font-size: var(--step-2);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2xs);
  }

  .service-body {
    font-size: var(--step-0);
    color: var(--color-ink-soft);
    max-width: var(--measure);
    line-height: 1.6;
  }

  /* The tech stack answers "with what", a different register than the three
     service cards ("what I do for you"). It is bound to the Diensten section as
     one demarcated block: the same raised surface family as the cards/chips
     (--color-surface-tint + --color-line-strong keyline + --radius), so it
     clearly belongs here, while a short warm keyline on its left edge (echoing
     the warm service numbers and card hover keyline) ties it to the section
     without turning it into a fourth card. */
  .tech {
    margin-top: var(--space-xl);
    position: relative;
    padding: var(--space-l);
    border: 1px solid var(--color-line-strong);
    border-radius: var(--radius);
    background: var(--color-surface-tint);
    overflow: hidden;
  }

  /* The warm keyline that binds the block to the section's accent voice. */
  .tech::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-warm);
  }

  /* The label reads as an eyebrow (uppercase, tracked, warm), the same register
     as the numbered section labels, so the block is recognisable as a heading
     of its own and not another card title. */
  .tech-label {
    font-size: var(--step--1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-warm);
    font-weight: 600;
    margin-bottom: var(--space-s);
  }

  .tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
  }

  .tech-item {
    font-size: var(--step--1);
    font-weight: 500;
    padding: 0.45rem 1rem;
    border: var(--border);
    border-radius: 999px;
    background: var(--color-bg-elevated);
    color: var(--color-ink);
    transition: border-color 0.2s var(--ease-out), color 0.2s var(--ease-out),
      background-color 0.2s var(--ease-out);
  }

  /* Light: the chips now sit inside the surface-tint block, so they take the
     lighter elevated ground to stand off the block instead of matching it. */
  :global(html[data-theme='light']) .tech-item {
    background: var(--color-bg-elevated);
    border-color: var(--color-line-strong);
  }

  :global(html[data-theme='light']) .tech-item:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Dark: give the chips the same gently raised surface as light, tuned to the
     charcoal ground. The elevated background already lifts them off the section;
     the stronger hairline (--color-line-strong, a real lifted dark line here)
     plus a soft shadow make each chip read as a discrete, premium token instead
     of melting into the page. Mirrors the cert badge's elevated-surface family. */
  :global(html[data-theme='dark']) .tech-item {
    /* Inside the elevated block, drop the chip to the section ground so it reads
       as a discrete token against the block instead of matching its surface. */
    background: var(--color-bg);
    border-color: var(--color-line-strong);
    box-shadow: 0 1px 2px -1px rgba(0, 0, 0, 0.5);
  }

  :global(html[data-theme='dark']) .tech-item:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (min-width: 48rem) {
    .service-card {
      grid-template-columns: 4rem 1fr;
      gap: var(--space-xl);
    }
  }
</style>
