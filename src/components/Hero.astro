---
import { getContent, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
---

<section class="hero">
  <div class="container hero-inner">
    <p class="hero-eyebrow reveal">{t.hero.eyebrow}</p>
    <div class="hero-name-block">
      <h1 class="hero-title reveal" style="--reveal-delay: 0.05s">
        {t.hero.name}
      </h1>
      <span class="hero-keyline reveal" style="--reveal-delay: 0.08s" aria-hidden="true"></span>
    </div>
    <p class="hero-headline reveal" style="--reveal-delay: 0.1s">{t.hero.headline}</p>
    <p class="hero-intro reveal" style="--reveal-delay: 0.15s">{t.hero.intro}</p>

    <div class="hero-actions reveal" style="--reveal-delay: 0.2s">
      <a class="btn btn-primary" href="#contact">{t.hero.ctaPrimary}</a>
      <a class="btn btn-secondary" href="#services">{t.hero.ctaSecondary}</a>
    </div>

    <p class="hero-location reveal" style="--reveal-delay: 0.25s">
      <span class="dot" aria-hidden="true"></span>
      {t.hero.location}
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(5rem, 14vh, 9rem) var(--space-2xl);
    overflow: hidden;
  }

  /* Two very soft radial glows: the dominant teal on the left and a smaller,
     warmer coral-amber pool on the right. Together they give the hero quiet
     depth and a touch of energy without ever competing with the type. Teal
     stays the larger, leading wash; the warm glow is the second voice. */
  .hero::before {
    content: '';
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 60vh;
    background:
      radial-gradient(
        55% 60% at 78% 12%,
        color-mix(in srgb, var(--color-warm) var(--warm-strength, 11%), transparent),
        transparent 68%
      ),
      radial-gradient(
        60% 60% at 30% 20%,
        color-mix(in srgb, var(--color-accent) var(--glow-strength, 9%), transparent),
        transparent 70%
      );
    pointer-events: none;
    z-index: -1;
  }

  .hero-inner {
    max-width: 56rem;
  }

  .hero-eyebrow {
    font-size: var(--step--1);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
    font-weight: 500;
    margin-bottom: var(--space-m);
  }

  .hero-title {
    font-size: var(--step-4);
    font-weight: 600;
    letter-spacing: -0.035em;
  }

  /* The name block shrinks to the rendered width of the name (fit-content),
     so the keyline below can take that exact width with width:100%. This makes
     the line track the full name on every breakpoint (the name uses fluid
     type) and stay left-aligned, without a hardcoded width that only covers
     part of it. Should the name ever wrap on a narrow screen, fit-content
     follows the widest line, so the keyline still spans the name block. */
  .hero-name-block {
    width: fit-content;
    max-width: 100%;
  }

  /* A fine accent keyline under the name: a warm->teal gradient (warm left,
     teal right) that brings the two brand voices together in one quiet mark
     and gives the hero a touch of rhythm. It now runs the full width of the
     name; kept thin (2px) so a line this long stays elegant and never reads as
     a heavy underline or personal-brand stripe. Both stops are WCAG-AA accent
     values per theme, so neither voice drops out against the dark charcoal or
     the light paper. Purely decorative, so the element is empty and aria-hidden. */
  .hero-keyline {
    display: block;
    width: 100%;
    height: 2px;
    margin-top: var(--space-s);
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--color-warm) 0%,
      var(--color-accent) 100%
    );
  }

  .hero-headline {
    font-size: var(--step-2);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-top: var(--space-m);
    max-width: 24ch;
  }

  .hero-intro {
    font-size: var(--step-1);
    color: var(--color-ink-soft);
    max-width: 46ch;
    margin-top: var(--space-m);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    margin-top: var(--space-l);
  }

  .hero-location {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--step--1);
    color: var(--color-ink-faint);
    margin-top: var(--space-xl);
  }

  /* Teal core with a warm-tinted ring: the two brand voices in one small mark. */
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-warm) var(--ring-strength, 18%), transparent);
  }
</style>
